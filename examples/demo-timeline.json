    },
    {
      "id": "lower-third-1",
      "component": "LowerThird",
      "trackId": "ui",
      "from": 15,
      "durationInFrames": 70,
      "props": {
        "name": "Sarah Chen",
        "title": "Chief Revenue Officer",
        "position": "bottom-left",
        "motion": { "type": "spring", "direction": "left", "durationInFrames": 18 }
