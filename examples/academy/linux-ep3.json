      "trackId": "content",
      "from": 122,
      "durationInFrames": 163,
      "props": {
        "text": "Every Linux file has three permission sets: owner, group, others. Each set has read (4), write (2), execute (1). chmod 755 = owner does everything, others can only read and execute.",
