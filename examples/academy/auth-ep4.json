      "from": 122,
      "durationInFrames": 163,
      "props": {
        "text": "Never store plaintext passwords. Hash them with bcrypt, scrypt, or Argon2. A hash is a one-way transformation — you verify by hashing the input and comparing, never by decrypting.",
